# ── Database (Neon PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=24h

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ─────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173

# ── Bcrypt ───────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
